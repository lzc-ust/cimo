# ── Python 字节码 & 缓存 ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo

# ── 构建产物 ─────────────────────────────────────────────────────────────
*.egg-info/
*.egg
dist/
build/
.eggs/

# ── 测试 & 覆盖率缓存 ───────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.xml

# ── 虚拟环境（如果有本地 venv） ─────────────────────────────────────────
.venv/
venv/
env/

# ── 编辑器 / IDE ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── 仿真输出产物（运行时生成，不纳入版本控制） ──────────────────────────
results/
outputs/
runs/
*.jsonl
*.json
!tests/**/*.json

# ── 操作系统文件 ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
